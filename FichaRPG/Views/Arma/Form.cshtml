@model ArmasViewModel
@{

}
<div class="container">
    <form asp-action="save">
        <input type="hidden" name="operacao" value="@ViewBag.Operacao" />

            <input type="hidden" id="Persona-id" name="PersonagemId" value="@ViewBag.Personagem" />
        
       
            <input hidden asp-for="Id" />
        
        <div class="row">
            <div class="col-md-3">
                <label>Nome:</label>
                <input class="bg-black text-white form-control" required asp-for="Nome" />
                <span class="text-danger" asp-validation-for="Nome"></span>
            </div>

            <div class="col-md-3">
                <label>Alcance:</label>
                <input class="bg-black text-white form-control" required asp-for="Alcance" />
                <span class="text-danger" asp-validation-for="Alcance"></span>
            </div>

            <div class="col-md-3">
                <label>Espaço:</label>
                <input class="bg-black text-white form-control" required asp-for="Espaco" />
                <span class="text-danger" asp-validation-for="Espaco"></span>
            </div>

            <div class="col-md-3">
                <label>Tipo:</label>
                <input class="bg-black text-white form-control" required asp-for="Tipo" />
                <span class="text-danger" asp-validation-for="Tipo"></span>
            </div>

            <div class="col-md-4">
                <label>Categoria:</label>
                <input class="bg-black text-white form-control" required asp-for="Categoria" />
                <span class="text-danger" asp-validation-for="Categoria"></span>
            </div>

            <div class="col-md-4">
                <label>Dano:</label>
                <input class="bg-black text-white form-control" required asp-for="Dano" />
                <span class="text-danger" asp-validation-for="Dano"></span>
            </div>

            <div class="col-md-4">
                <label>Crítico:</label>
                <input class="bg-black text-white form-control" required asp-for="Critico" />
                <span class="text-danger" asp-validation-for="Critico"></span>
            </div>
        </div>
        <br />
        @if (ViewBag.Operacao == "I")
        {
            <button class="btn Rpg-Button" type="submit">Adicionar ao inventário</button>
        }
        else
        {
            <button class="btn Rpg-Button" type="submit">Salvar Alterações</button>
        }

    </form>
</div>